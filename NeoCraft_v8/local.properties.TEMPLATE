# NeoCraft local.properties — TEMPLATE
# Copy this file to local.properties and fill in your keys.
# NEVER commit local.properties to Git — it is already in .gitignore

# --- AI Keys ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# --- Firebase (Auth + Firestore) ---
# 1. Go to https://console.firebase.google.com
# 2. Create project "neocraft-game"
# 3. Add Android app with package "com.neocraft.game"
# 4. Enable Authentication > Email/Password
# 5. Enable Firestore Database
# 6. Copy the Web API key from Project Settings > General
FIREBASE_API_KEY=your_firebase_web_api_key_here
FIREBASE_PROJECT_ID=your_project_id_here

# SDK key (from Android Studio SDK manager, auto-filled)
sdk.dir=/path/to/Android/sdk
